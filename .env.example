# App configuration
LOAD_DOTENV=true
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=your_tavily_api_key_here

# PostgreSQL configuration
POSTGRES_DB=inova_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional: use a full database URL instead of individual DB fields
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/inova_db